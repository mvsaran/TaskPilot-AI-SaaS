# Database
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/taskpilot_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Server & Auth Security
PORT=3000
JWT_SECRET="supersecretjwtkeyforTaskPilotAIEnterprise2026!"
JWT_REFRESH_SECRET="supersecretrefreshjwtkeyforTaskPilotAI2026!"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# AI Configuration (OpenAI + Simulation)
# Set OPENAI_API_KEY if testing against live OpenAI GPT-4o / GPT-5.5
OPENAI_API_KEY=""
# Set AI_SIMULATION_MODE=true to enable intelligent high-fidelity deterministic simulation without incurring API costs
AI_SIMULATION_MODE="true"
AI_MODEL_NAME="gpt-4o"
AI_EMBEDDING_MODEL="text-embedding-3-small"

# Frontend Configuration
VITE_API_BASE_URL="http://localhost:3000/api/v1"
